rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para obtener el perfil del usuario de forma segura
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    // Identificar si el usuario es Super Admin de Tane (por email o por rol)
    function isSuperAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'admin@tanesolutions.com' || 
         (getUserData() != null && getUserData().role == 'superadmin'));
    }

    // Verificar si el usuario tiene permiso sobre este restaurante (admin o superadmin, no staff)
    function isRestaurantAdmin(restaurantId) {
      let u = getUserData();
      return request.auth != null &&
        (isSuperAdmin() || (u != null && u.restaurant_id == restaurantId && u.role == 'admin'));
    }

    // Staff también puede gestionar reservas (confirmar, cancelar, notas) pero no mesas ni perfil
    function isRestaurantMember(restaurantId) {
      let u = getUserData();
      return request.auth != null &&
        (isSuperAdmin() || (u != null && u.restaurant_id == restaurantId && u.role in ['admin', 'staff']));
    }

    match /reservas/{reservaId} {
      // Anyone can create a reservation (public booking form)
      allow create: if request.resource.data.restaurant_id != null;
      // Public read needed for slot availability on the booking page
      allow read: if true;
      allow update, delete: if isRestaurantMember(resource.data.restaurant_id);
    }

    match /mesas/{mesaId} {
      allow read: if true;
      // Crear y borrar mesas: solo admin o superadmin
      allow create: if isRestaurantAdmin(request.resource.data.restaurant_id);
      allow delete: if isRestaurantAdmin(resource.data.restaurant_id);
      // Actualizar mesas:
      //   - Admin puede cambiar cualquier campo (nombre, posición, capacidad, estado)
      //   - Staff puede cambiar SOLO el campo 'estado' (operativo: libre/reservada/ocupada)
      allow update: if isRestaurantAdmin(resource.data.restaurant_id)
        || (isRestaurantMember(resource.data.restaurant_id)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado']));
    }

    match /restaurants/{restaurantId} {
      // Public read: booking page needs restaurant name and horarios config
      allow read: if true;
      // Crear y eliminar restaurantes: solo superadmin
      allow create, delete: if isSuperAdmin();
      // Actualizar:
      //   Superadmin puede cambiar todo (plan, activo, datos, stripe...)
      //   Admin puede cambiar solo datos operativos (nombre, horarios, contacto, modo_confirmacion)
      //   pero NO puede tocar plan, activo ni campos de facturación Stripe
      allow update: if isSuperAdmin()
        || (isRestaurantAdmin(restaurantId)
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['plan', 'activo', 'stripe_customer_id',
                         'stripe_subscription_id', 'plan_activo_desde']));
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
    }
    
    // Colección de logs o auditoría si fuera necesario
    match /system_logs/{logId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
