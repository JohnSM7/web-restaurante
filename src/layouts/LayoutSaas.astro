---
interface Props {
  title?:       string;
  description?: string;
}
const {
  title       = 'Tane Booking — Plataforma de Reservas para Restaurantes',
  description = 'Sistema de reservas online para restaurantes. Gestiona mesas, confirmaciones y clientes desde un panel profesional. Prueba gratuita 14 días.',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;500;600;700;800&display=swap" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-family: 'Work Sans', system-ui, sans-serif; color: #111; background: #fff; }
    body { min-height: 100vh; display: flex; flex-direction: column; }
    a { color: inherit; text-decoration: none; }

    /* ── Nav ── */
    .saas-nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid #f0f0f0;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2rem; height: 60px;
    }
    .saas-logo {
      font-size: 1rem; font-weight: 800; letter-spacing: 0.15em;
      text-transform: uppercase;
    }
    .saas-logo em { font-style: italic; font-weight: 300; color: #777; }
    .saas-nav-links { display: flex; align-items: center; gap: 1.5rem; }
    .saas-nav-links a {
      font-size: 0.75rem; font-weight: 600;
      letter-spacing: 0.08em; text-transform: uppercase; color: #555;
      transition: color 0.15s;
    }
    .saas-nav-links a:hover { color: #000; }
    .saas-nav-links a.active { color: #000; }
    .nav-cta {
      background: #000; color: #fff !important;
      padding: 0.5rem 1.25rem; border-radius: 4px;
      font-weight: 700 !important;
      transition: opacity 0.15s !important;
    }
    .nav-cta:hover { opacity: 0.8; }
    @media (max-width: 600px) {
      .saas-nav { padding: 0 1rem; }
      .saas-nav-links a:not(.nav-cta) { display: none; }
    }

    /* ── Main ── */
    main { flex: 1; }

    /* ── Footer ── */
    .saas-footer {
      border-top: 1px solid #f0f0f0;
      padding: 2rem;
      display: flex; flex-wrap: wrap;
      align-items: center; justify-content: space-between;
      gap: 1rem;
      font-size: 0.65rem; color: #999;
      letter-spacing: 0.08em; text-transform: uppercase;
    }
    .saas-footer a { color: #999; transition: color 0.15s; }
    .saas-footer a:hover { color: #000; }
    .footer-links { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  </style>
</head>
<body>

  <nav class="saas-nav">
    <a href="/registro" class="saas-logo">TANE <em>Booking</em></a>
    <div class="saas-nav-links">
      <a href="/precios" class={currentPath === '/precios' ? 'active' : ''}>Precios</a>
      <a href="/admin/dashboard">Acceder</a>
      <a href="/registro" class={`nav-cta ${currentPath === '/registro' ? 'active' : ''}`}>
        Prueba gratis
      </a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="saas-footer">
    <span>© {new Date().getFullYear()} Tane Solutions · Sistema de reservas para restaurantes</span>
    <div class="footer-links">
      <a href="/precios">Precios</a>
      <a href="/legal/terminos">Términos de uso</a>
      <a href="/legal/privacidad">Privacidad</a>
      <a href="mailto:admin@tanesolutions.com">Contacto</a>
    </div>
  </footer>

</body>
</html>
