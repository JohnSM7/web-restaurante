---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SobreNosotros from '../components/SobreNosotros.astro';
import Carta from '../components/Carta.astro';
import Experiencia from '../components/Experiencia.astro';
import Reservas from '../components/Reservas.astro';
import Testimonios from '../components/Testimonios.astro';
import Ubicacion from '../components/Ubicacion.astro';
import Blog from '../components/Blog.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="THE EDITORIAL | Restaurante Mediterráneo en Madrid – Alta Cocina"
  description="Restaurante mediterráneo en Madrid. Reserva tu mesa en Calle de Serrano, 42 - Barrio de Salamanca. Ingredientes frescos, cocina artesanal y ambiente exclusivo. Comida mediterránea Madrid."
>
  <Nav />
  <main id="main-content">
    <Hero />
    <SobreNosotros />
    <Carta />
    <Experiencia />
    <Reservas />
    <Testimonios />
    <Blog />
    <Ubicacion />
  </main>
  <Footer />

</Layout>
