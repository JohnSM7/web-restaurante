---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SobreNosotros from '../components/SobreNosotros.astro';
import Carta from '../components/Carta.astro';
import Experiencia from '../components/Experiencia.astro';
import Reservas from '../components/Reservas.astro';
import Testimonios from '../components/Testimonios.astro';
import Ubicacion from '../components/Ubicacion.astro';
import Blog from '../components/Blog.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="THE EDITORIAL | Restaurante Mediterráneo en Madrid – Alta Cocina"
  description="Restaurante mediterráneo en Madrid. Reserva tu mesa en Calle de Serrano, 42 - Barrio de Salamanca. Ingredientes frescos, cocina artesanal y ambiente exclusivo. Comida mediterránea Madrid."
>
  <Nav />
  <main id="main-content">
    <Hero />
    <SobreNosotros />
    <Carta />
    <Experiencia />
    <Reservas />
    <Testimonios />
    <Blog />
    <Ubicacion />
  </main>
  <Footer />

  <!-- Floating Action Button – always visible -->
  <a href="#reservas" class="fab" id="fab-reservar" aria-label="Reservar mesa en The Editorial Madrid">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
    Reservar
  </a>
</Layout>
