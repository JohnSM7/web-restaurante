---
import Layout from '../layouts/Layout.astro';
import BookingForm from '../components/BookingForm.vue';

const restaurantId = Astro.url.searchParams.get('id') || 'the-editorial';
---

<Layout
  title="Reservas · The Editorial"
  description="Reserva tu mesa en The Editorial, experiencia mediterránea de alta cocina."
>
  <main class="booking-page">

    <!-- Left: atmospheric image column -->
    <div class="booking-img-col" aria-hidden="true">
      <img
        src="https://images.unsplash.com/photo-1550966871-3ed3cdb5ed0c?q=80&w=2070&auto=format&fit=crop"
        alt="Interior del restaurante The Editorial"
        class="booking-bg-img"
        loading="eager"
        fetchpriority="high"
      />
      <div class="booking-img-overlay"></div>
      <a href="/" class="booking-back-link">
        Demo <em>Hostelería</em>
      </a>
    </div>

    <!-- Right: booking form -->
    <div class="booking-content-col">
      <div class="booking-inner">

        <BookingForm client:only="vue" restaurantId={restaurantId} />

      </div>
    </div>

  </main>
</Layout>

<style>
  .booking-page {
    min-height: 100vh;
    display: flex;
  }

  /* ── Image column ──────────────────────────── */
  .booking-img-col {
    display: none;
    position: relative;
    flex: 5;
  }
  @media (min-width: 768px) {
    .booking-img-col { display: block; }
  }
  @media (min-width: 1024px) {
    .booking-img-col { flex: 1; }
    .booking-content-col { flex: 1; }
  }

  .booking-bg-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    filter: grayscale(15%);
  }
  .booking-img-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to right, transparent 60%, rgba(249,249,249,0.08));
  }
  .booking-back-link {
    position: absolute; top: 2.5rem; left: 2.5rem;
    color: #fff; font-family: 'Noto Serif', Georgia, serif;
    font-size: 1.375rem; font-weight: 300;
    letter-spacing: 0.02em;
    text-decoration: none; mix-blend-mode: difference;
    transition: opacity 0.2s;
  }
  .booking-back-link:hover { opacity: 0.7; }

  /* ── Content column ────────────────────────── */
  .booking-content-col {
    flex: 7;
    display: flex; align-items: center; justify-content: center;
    padding: 5rem 1.5rem;
    background: var(--surface, #f9f9f9);
    overflow-y: auto;
  }
  @media (min-width: 640px) {
    .booking-content-col { padding: 5rem 3rem; }
  }
  @media (min-width: 1024px) {
    .booking-content-col { padding: 5rem 5rem; }
  }

  .booking-inner {
    width: 100%;
    max-width: 560px;
  }

</style>
