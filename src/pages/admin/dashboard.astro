---
/**
 * TANE Admin Dashboard
 * Panel CRM multi-tenant — carga fullscreen, sin Layout público
 */
import AdminTable from '../../components/AdminTable.vue';

const restaurantId = Astro.url.searchParams.get('id') || 'the-editorial';
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard · Tane Booking System</title>
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#0a0a0a" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black" />
  <meta name="apple-mobile-web-app-title" content="Tane Booking" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/icons/icon.svg" />
  <link rel="manifest" href="/manifest.json" />
  <!-- Google Fonts: heredadas del global.css -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,300;0,400;1,300&family=Work+Sans:wght@400;500;600;700;800&display=swap" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; }
    body {
      font-family: 'Work Sans', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      background: #f5f5f5;
    }
    #app { height: 100%; }
  </style>
</head>
<body>
  <div id="app">
    <!--
      client:only="vue" — evita el SSR del componente.
      El panel admin usa Firebase Auth (async) y Teleport al body,
      lo que causa hydration mismatch con client:load.
    -->
    <AdminTable client:only="vue" restaurantId={restaurantId} />
  </div>
  <script>
    // Register Service Worker for PWA
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>
</body>
</html>
