---
// Blog section
const articulos = [
  {
    slug: 'que-es-dieta-mediterranea',
    titulo: 'Qué es la dieta mediterránea y por qué es Patrimonio de la Humanidad',
    extracto: 'Descubre los pilares de la alimentación que ha conquistado al mundo científico. La UNESCO la reconoció como bien cultural inmaterial en 2010, y hoy sabemos exactamente por qué vivos más y mejor gracias a ella.',
    categoria: 'Cultura Gastronómica',
    minLectura: '6 min',
    fecha: '18 Mar 2025',
  },
  {
    slug: 'beneficios-aceite-oliva-virgen-extra',
    titulo: 'Beneficios del aceite de oliva virgen extra: el oro líquido mediterráneo',
    extracto: 'El aceite de oliva virgen extra es el corazón de nuestra cocina. Analizamos sus propiedades antioxidantes, su papel en la prevención cardiovascular y cómo elegir un AOVE de calidad.',
    categoria: 'Ingredientes',
    minLectura: '5 min',
    fecha: '2 Feb 2025',
  },
  {
    slug: 'mejores-platos-mediterraneos-madrid',
    titulo: 'Los mejores platos mediterráneos en Madrid: una guía imprescindible',
    extracto: 'Madrid se ha convertido en la capital de la cocina mediterránea fuera del litoral. Desde el arroz de senyoret hasta la lubina a la sal, te contamos cuáles son los platos que no puedes perderte en la capital.',
    categoria: 'Gastronomía Madrid',
    minLectura: '8 min',
    fecha: '15 Ene 2025',
  },
];
---

<section class="blog section" id="blog" aria-labelledby="blog-heading">
  <div class="container">
    <div class="blog__header">
      <div>
        <p class="label-md muted reveal">Blog gastronómico</p>
        <h2 class="headline-lg reveal delay-1" id="blog-heading">
          Historias del<br />
          <span class="italic">Mediterráneo.</span>
        </h2>
      </div>
      <a href="#blog" class="btn-ghost reveal delay-2" id="blog-all-btn" style="align-self:flex-end;">
        Ver todos los artículos
      </a>
    </div>

    <div class="blog__grid">
      {articulos.map((art, i) => (
        <article class={`blog__card reveal delay-${i + 1}`} aria-label={art.titulo}>
          <header class="blog__card-header">
            <span class="label-md muted">{art.categoria}</span>
            <div class="blog__card-meta">
              <time class="label-md muted" datetime={art.fecha}>{art.fecha}</time>
              <span class="label-md muted">·</span>
              <span class="label-md muted">{art.minLectura} lectura</span>
            </div>
          </header>

          <h3 class="headline-sm blog__card-title">
            <a href={`/blog/${art.slug}`} class="blog__card-link">{art.titulo}</a>
          </h3>

          <p class="body-md muted blog__card-extracto">{art.extracto}</p>

          <a href={`/blog/${art.slug}`} class="blog__read-more label-md" aria-label={`Leer: ${art.titulo}`}>
            Leer artículo →
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .blog {
    background: var(--surface);
  }

  .blog__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: var(--sp-6);
    margin-bottom: var(--sp-16);
  }

  .blog__grid {
    display: grid;
    gap: var(--sp-1);
  }

  @media (min-width: 768px) {
    .blog__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .blog__card {
    background: var(--surface-container-lowest);
    padding: var(--sp-8);
    display: grid;
    gap: var(--sp-5);
    align-content: start;
    transition: box-shadow 0.3s var(--ease-out);
  }

  .blog__card:hover {
    box-shadow: 0 20px 40px rgba(0,0,0,0.04);
  }

  .blog__card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--sp-2);
    padding-bottom: var(--sp-5);
    border-bottom: 1px solid var(--outline-variant);
  }

  .blog__card-meta {
    display: flex;
    gap: var(--sp-2);
    align-items: center;
  }

  .blog__card-title {
    line-height: 1.3;
  }

  .blog__card-link {
    transition: opacity 0.2s;
    display: block;
  }

  .blog__card-link:hover { opacity: 0.65; }

  .blog__card-extracto {
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
  }

  .blog__read-more {
    color: var(--on-surface-variant);
    border-bottom: 1px solid var(--outline-variant);
    display: inline-block;
    padding-bottom: 2px;
    transition: border-color 0.2s, color 0.2s;
  }

  .blog__read-more:hover {
    color: var(--primary);
    border-color: var(--primary);
  }
</style>
