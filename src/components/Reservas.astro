---
// Reservas section
import BookingForm from './BookingForm.vue';
---
<section class="reservas section" id="reservas" aria-labelledby="reservas-heading">
  <div class="reservas__container">
    <div class="reservas__grid">
    <div class="reservas__info">
      <p class="label-md muted reveal">Reservas</p>
      <h2 class="headline-lg reveal delay-1" id="reservas-heading">
        Reserva tu mesa<br />
        <span class="italic">en Madrid</span>
      </h2>
      <p class="body-lg muted reveal delay-2">
        Para grupos de más de 8 personas, por favor contáctenos telefónicamente. Estaremos encantados de diseñar una experiencia personalizada para su ocasión especial.
      </p>

      <div class="reservas__contact reveal delay-3">
        <a href="tel:+34912345678" class="reservas__contact-item" aria-label="Llamar al restaurante">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <div>
            <span class="label-md">Teléfono</span>
            <p class="body-md">+34 912 345 678</p>
          </div>
        </a>

        <a href="mailto:reservas@theeditorial.es" class="reservas__contact-item" aria-label="Enviar email al restaurante">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <div>
            <span class="label-md">Email</span>
            <p class="body-md">reservas@theeditorial.es</p>
          </div>
        </a>
      </div>
    </div>

    <div class="reservas__form-wrap">
      <BookingForm client:load />
    </div>
  </div>
</section>

<style>
  .reservas {
    background: var(--surface-container-lowest);
  }

  .reservas__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0; /* Full width mobile */
  }

  @media (min-width: 768px) {
    .reservas__container {
      padding: 0 var(--sp-10);
    }
  }

  .reservas__grid {
    display: flex;
    flex-direction: column;
    gap: var(--sp-12);
  }

  @media (min-width: 1024px) {
    .reservas__grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: var(--sp-24);
      align-items: center;
    }
  }

  .reservas__info {
    padding: var(--sp-16) var(--sp-8) 0;
  }

  @media (min-width: 1024px) {
    .reservas__info {
      padding: 0;
    }
  }

  /* Form Wrap */
  .reservas__form-wrap {
    background: #ffffff; /* pure white for maximum readability */
    padding: var(--sp-10) var(--sp-6);
    width: 100%;
    box-shadow: 0 10px 40px rgba(0,0,0,0.05); /* Subtle shadow for depth */
  }

  @media (min-width: 1024px) {
    .reservas__form-wrap {
      padding: var(--sp-20);
    }
  }

  .reservas__form {
    display: grid;
    gap: var(--sp-5);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }

  .form-field {
    display: grid;
    gap: var(--sp-2);
  }

  .form-field label {
    color: var(--on-surface-variant);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 300;
    color: var(--on-surface);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--outline);
    padding: var(--sp-3) 0;
    outline: none;
    transition: border-color 0.25s;
    width: 100%;
    border-radius: 0;
    -webkit-appearance: none;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    border-bottom-color: var(--primary);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-field select option {
    background: var(--surface-container-lowest);
  }
  .reservas__contact {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
    margin-top: var(--sp-8);
    padding-top: var(--sp-8);
    border-top: 1px solid var(--outline-variant);
  }

  .reservas__contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
  }

  .reservas__contact-item svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--gold);
    margin-top: 2px;
  }

  .reservas__contact-item div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
</style>


