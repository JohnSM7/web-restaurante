---
// Reservas section
---
<section class="reservas section" id="reservas" aria-labelledby="reservas-heading">
  <div class="container reservas__grid">
    <div class="reservas__info">
      <p class="label-md muted reveal">Reservas</p>
      <h2 class="headline-lg reveal delay-1" id="reservas-heading">
        Reserva tu mesa<br />
        <span class="italic">en Madrid</span>
      </h2>
      <p class="body-lg muted reveal delay-2">
        Para grupos de más de 8 personas, por favor contáctenos telefónicamente. Estaremos encantados de diseñar una experiencia personalizada para su ocasión especial.
      </p>

      <div class="reservas__contact reveal delay-3">
        <a href="tel:+34912345678" class="reservas__contact-item" aria-label="Llamar al restaurante">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <div>
            <span class="label-md">Teléfono</span>
            <p class="body-md">+34 912 345 678</p>
          </div>
        </a>

        <a href="mailto:reservas@theeditorial.es" class="reservas__contact-item" aria-label="Enviar email al restaurante">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <div>
            <span class="label-md">Email</span>
            <p class="body-md">reservas@theeditorial.es</p>
          </div>
        </a>
      </div>
    </div>

    <div class="reservas__form-wrap reveal delay-2">
      <form class="reservas__form" id="form-reservas" name="reservas" method="POST" novalidate aria-label="Formulario de reserva de mesa">
        <h3 class="headline-sm" style="margin-bottom:var(--sp-6);">Solicitar reserva</h3>

        <div class="form-field">
          <label class="label-md" for="nombre">Nombre completo</label>
          <input type="text" id="nombre" name="nombre" required placeholder="María García López" autocomplete="name" />
        </div>

        <div class="form-field">
          <label class="label-md" for="email">Correo electrónico</label>
          <input type="email" id="email" name="email" required placeholder="maria@example.com" autocomplete="email" />
        </div>

        <div class="form-row">
          <div class="form-field">
            <label class="label-md" for="telefono">Teléfono</label>
            <input type="tel" id="telefono" name="telefono" placeholder="+34 600 000 000" autocomplete="tel" />
          </div>
          <div class="form-field">
            <label class="label-md" for="personas">Personas</label>
            <select id="personas" name="personas" required>
              <option value="" disabled selected>Nº comensales</option>
              {[1,2,3,4,5,6,7,8].map(n => <option value={n}>{n} {n === 1 ? 'persona' : 'personas'}</option>)}
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label class="label-md" for="fecha">Fecha</label>
            <input type="date" id="fecha" name="fecha" required />
          </div>
          <div class="form-field">
            <label class="label-md" for="hora">Hora</label>
            <select id="hora" name="hora" required>
              <option value="" disabled selected>Servicio</option>
              <optgroup label="Almuerzo">
                <option value="13:30">13:30 h</option>
                <option value="14:00">14:00 h</option>
                <option value="14:30">14:30 h</option>
                <option value="15:00">15:00 h</option>
                <option value="15:30">15:30 h</option>
              </optgroup>
              <optgroup label="Cena">
                <option value="20:30">20:30 h</option>
                <option value="21:00">21:00 h</option>
                <option value="21:30">21:30 h</option>
                <option value="22:00">22:00 h</option>
              </optgroup>
            </select>
          </div>
        </div>

        <div class="form-field">
          <label class="label-md" for="notas">Notas o alergias (opcional)</label>
          <textarea id="notas" name="notas" rows="3" placeholder="Alergias, ocasión especial, preferencias de mesa..."></textarea>
        </div>

        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;" id="submit-reserva">
          Confirmar reserva
        </button>

        <p class="label-md muted" style="text-align:center;margin-top:var(--sp-3);">
          Recibirás confirmación por email en menos de 2 horas.
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .reservas {
    background: var(--surface-container-lowest);
  }

  .reservas__grid {
    display: grid;
    gap: var(--sp-16);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .reservas__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .reservas__info {
    display: grid;
    gap: var(--sp-8);
  }

  .reservas__contact {
    display: grid;
    gap: var(--sp-5);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--outline-variant);
  }

  .reservas__contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
    transition: opacity 0.2s;
  }

  .reservas__contact-item:hover { opacity: 0.7; }

  .reservas__contact-item svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--gold);
    margin-top: 2px;
  }

  .reservas__contact-item div {
    display: grid;
    gap: var(--sp-1);
  }

  /* Form */
  .reservas__form-wrap {
    background: var(--surface-container-low);
    padding: var(--sp-10);
  }

  .reservas__form {
    display: grid;
    gap: var(--sp-5);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }

  .form-field {
    display: grid;
    gap: var(--sp-2);
  }

  .form-field label {
    color: var(--on-surface-variant);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 300;
    color: var(--on-surface);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--outline);
    padding: var(--sp-3) 0;
    outline: none;
    transition: border-color 0.25s;
    width: 100%;
    border-radius: 0;
    -webkit-appearance: none;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    border-bottom-color: var(--primary);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 80px;
  }

  .form-field select option {
    background: var(--surface-container-lowest);
  }
</style>

<script>
  const form = document.getElementById('form-reservas');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-reserva');
    if (btn) {
      btn.textContent = '✓ Reserva enviada';
      btn.setAttribute('disabled', 'true');
      btn.style.background = '#3b3b3b';
    }
  });

  // Set min date to today
  const dateInput = document.getElementById('fecha') as HTMLInputElement;
  if (dateInput) {
    const today = new Date().toISOString().split('T')[0];
    dateInput.min = today;
  }
</script>
